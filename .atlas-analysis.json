  "keyFeatures": [
    "Automated PR review with Claude Sonnet 4.6",
    "Neo4j knowledge graph for file experts and related PRs",
    "Mem0 semantic memory for project patterns and developer habits",
    "MCP server exposing PR reviews, verdicts, and repo health",
    "MCP client pulling context from Linear, Sentry, and Slack",
    "GitHub OAuth authentication with JWT",
    "FastAPI backend with async PostgreSQL and Neo4j",
    "Next.js 15 frontend with React 19 and TailwindCSS 4",
    "Parallel review agents mode with specialized security, performance, and style agents"
  ],
